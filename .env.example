# API
APP_NAME=Sales Diagnostics API
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/sales_diagnostics
# Public domain used in links sent to Telegram.
WEB_BASE_URL=https://example.com
INTERNAL_API_BASE_URL=http://localhost:8000/api
RATE_LIMIT_PER_MINUTE=120

# Public domain for reverse-proxy (Caddy in deploy/docker-compose.yml).
DOMAIN_NAME=example.com

# Telegram
TELEGRAM_CLIENT_BOT_TOKEN=
TELEGRAM_OWNER_BOT_TOKEN=
OWNER_TELEGRAM_CHAT_ID=

# YandexGPT (Foundation Models)
YANDEX_FOLDER_ID=
# Prefer one of:
YANDEX_API_KEY=
YANDEX_IAM_TOKEN=
# Optional override (otherwise built from folder id):
YANDEX_MODEL_URI=
YANDEX_COMPLETION_URL=https://llm.api.cloud.yandex.net/foundationModels/v1/completion
YANDEX_LLM_TIMEOUT_SECONDS=30

# Web
# Prefer same-origin proxy via Next.js rewrites:
NEXT_PUBLIC_API_BASE_URL=/api
# Upstream FastAPI for Next.js rewrites (server-side):
API_UPSTREAM_URL=http://localhost:8000
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_client_bot
